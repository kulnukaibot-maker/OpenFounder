# OpenFounder Configuration
# Copy this to .env and fill in your values

# Database (defaults work with docker-compose)
DATABASE_URL=postgresql://openfounder:openfounder_dev@localhost:5433/openfounder
DB_PORT=5433
POSTGRES_PASSWORD=openfounder_dev

# LLM
ANTHROPIC_API_KEY=sk-ant-...
# Model escalation: Haiku (default) → Sonnet → Opus
CEO_MODEL=claude-haiku-4-5-20251001
CREW_MODEL=claude-haiku-4-5-20251001
ESCALATION_MODEL=claude-sonnet-4-20250514
MAX_MODEL=claude-opus-4-20250514
CEO_MAX_TOKENS=4096
CREW_MAX_TOKENS=8192
CEO_TEMPERATURE=0.3

# Engineering crew — code execution
ENGINEERING_MODEL=claude-sonnet-4-20250514
ENGINEERING_MAX_TOKENS=16384
ENGINEERING_AUTO_APPLY=false
ENGINEERING_REPO_PATH=
ENGINEERING_TEST_TIMEOUT=120

# Marketing crew — content calendar
MARKETING_MODEL=claude-sonnet-4-20250514
MARKETING_MAX_TOKENS=8192
MARKETING_AUTO_PUBLISH=false

# Discord (for approval notifications + morning briefings)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Logging
LOG_LEVEL=INFO
